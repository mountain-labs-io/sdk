{
  "name": "@mountain-labs/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the Mountain Labs headless CMS API",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mountain-labs-io/js-sdk.git",
    "directory": "packages/sdk"
  },
  "keywords": [
    "mountain-labs",
    "headless-cms",
    "cms",
    "sdk",
    "graphql",
    "typescript"
  ],
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "release": "npm run build && npm publish"
  },
  "devDependencies": {
    "msw": "^2.13.6",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  }
}
